# Copy this file to .env and fill in real values.
# Never commit the real .env file — it is already in .gitignore.

# LLM provider key (used by the gap-generation module).
# Get a free key (no credit card needed) at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — increases OpenAlex / Crossref rate limits when set
OPENALEX_MAILTO=your_email@example.com
CROSSREF_MAILTO=your_email@example.com
